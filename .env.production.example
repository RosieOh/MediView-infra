# 프로덕션 환경변수 템플릿. 실제 값 채운 뒤 `.env.production` 으로 복사(커밋 금지).
#   docker compose --env-file .env.production -f compose.yaml -f compose.prod.yml up -d
IMAGE_TAG=latest

DB_NAME=mediview
DB_USER=mediview
DB_PASSWORD=CHANGE-ME
DB_ROOT_PASSWORD=CHANGE-ME

# openssl rand -base64 32
JWT_SECRET=CHANGE-ME-base64-32bytes
APP_ENCRYPTION_KEY=CHANGE-ME-base64-32bytes
CORS_ALLOWED_ORIGIN_PATTERNS=https://*.mediview.example.com

EXTERNAL_IP=203.0.113.10
TURN_REALM=turn.mediview.example.com
TURN_SECRET=CHANGE-ME

OPENAI_API_KEY=
GRAFANA_ADMIN_PASSWORD=CHANGE-ME
