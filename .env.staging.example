# 스테이징 환경변수 템플릿. 실제 값 채운 뒤 `.env.staging` 으로 복사(커밋 금지).
#   docker compose --env-file .env.staging -f compose.yaml -f compose.staging.yml up -d
IMAGE_TAG=develop

DB_NAME=mediview
DB_USER=mediview
DB_PASSWORD=CHANGE-ME
DB_ROOT_PASSWORD=CHANGE-ME

JWT_SECRET=CHANGE-ME-base64-32bytes
APP_ENCRYPTION_KEY=CHANGE-ME-base64-32bytes
CORS_ALLOWED_ORIGIN_PATTERNS=https://*.staging.mediview.example.com

EXTERNAL_IP=203.0.113.11
TURN_REALM=turn.staging.mediview.example.com
TURN_SECRET=CHANGE-ME

OPENAI_API_KEY=
GRAFANA_ADMIN_PASSWORD=CHANGE-ME
